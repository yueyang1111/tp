@startuml
title Sequence Diagram for DeleteItemCommand (Main Control Flow Only)

autonumber
hide footbox

actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser
participant ":DeleteCommandParser" as DeleteCommandParser
participant ":DeleteItemCommand" as DeleteItemCommand
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":Item" as Item

User -> UI: enter delete item command
activate UI
UI -> InventoryDock: input
activate InventoryDock
InventoryDock -> Parser: parse(input)
activate Parser

Parser -> DeleteCommandParser: parse(arguments)
activate DeleteCommandParser

DeleteCommandParser -> DeleteCommandParser: parseDeleteItem(categoryName, indexString)
activate DeleteCommandParser
DeleteCommandParser --> DeleteCommandParser: itemIndex
deactivate DeleteCommandParser

create DeleteItemCommand
DeleteCommandParser -> DeleteItemCommand: DeleteItemCommand(categoryName, itemIndex)
activate DeleteItemCommand
DeleteItemCommand --> DeleteCommandParser: command
deactivate DeleteItemCommand
DeleteCommandParser --> Parser: command
deactivate DeleteCommandParser
Parser --> InventoryDock: command
deactivate Parser

InventoryDock -> DeleteItemCommand: execute(inventory, ui)
activate DeleteItemCommand
DeleteItemCommand -> Inventory: findCategoryByName(categoryName)
activate Inventory
Inventory --> DeleteItemCommand: category
deactivate Inventory

alt category is null
    DeleteItemCommand -> UI: showCategoryNotFound(categoryName)
    activate UI
    UI --> User: display error
    deactivate UI
else category found
    alt itemIndex < 1 or itemIndex > category.getItemCount()
        DeleteItemCommand -> UI: showError("Invalid item index: ...")
        activate UI
        UI --> User: display error
        deactivate UI
    else valid index
        DeleteItemCommand -> Category: getItem(itemIndex - 1)
        activate Category
        Category --> DeleteItemCommand: item
        deactivate Category

        DeleteItemCommand -> Category: removeItem(itemIndex - 1)
        activate Category
        Category --> DeleteItemCommand
        deactivate Category

        DeleteItemCommand -> Item: getName()
        activate Item
        Item --> DeleteItemCommand: itemName
        deactivate Item

        DeleteItemCommand -> UI: showItemDeleted(itemName, categoryName)
        activate UI
        UI --> User: display confirmation
        deactivate UI
    end
end

DeleteItemCommand --> InventoryDock: display information
deactivate DeleteItemCommand
deactivate InventoryDock
deactivate UI
@enduml

