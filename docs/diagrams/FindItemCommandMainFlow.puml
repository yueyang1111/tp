@startuml
title Sequence Diagram for FindItemCommand (Main Flow: expiryDate)

autonumber
hide footbox

actor User
participant ":UI" as UI
participant ":Duke" as Duke
participant ":Parser" as Parser
participant ":FindItemParser" as FindItemParser
participant ":FindItemByExpiryDateCommand" as FindItemByExpiryDateCommand
participant ":DateParser" as DateParser
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":Item" as Item

User -> UI: enter find expiryDate command
activate UI
UI -> Duke: input
activate Duke
Duke -> Parser: parse(input)
activate Parser

Parser -> FindItemParser: parse(arguments)
activate FindItemParser
create FindItemByExpiryDateCommand
FindItemParser -> FindItemByExpiryDateCommand: FindItemByExpiryDateCommand(name)
activate FindItemByExpiryDateCommand
FindItemByExpiryDateCommand --> FindItemParser: command
FindItemParser --> Parser: command
deactivate FindItemParser
Parser --> Duke: command
deactivate Parser

Duke -> FindItemByExpiryDateCommand: execute(inventory, ui)
activate FindItemByExpiryDateCommand
FindItemByExpiryDateCommand -> DateParser: parseDate(expiryDateInput)
activate DateParser
DateParser --> FindItemByExpiryDateCommand: cutoffDate
deactivate DateParser

FindItemByExpiryDateCommand -> Inventory: getCategories()
activate Inventory
Inventory --> FindItemByExpiryDateCommand: categories
deactivate Inventory

loop for each category
    FindItemByExpiryDateCommand -> Category: getItems()
    activate Category
    Category --> FindItemByExpiryDateCommand: items
    deactivate Category

    loop for each item
        FindItemByExpiryDateCommand -> Item: getExpiryDate()
        activate Item
        Item --> FindItemByExpiryDateCommand: itemExpiryDate
        deactivate Item

        alt itemExpiryDate != null
            FindItemByExpiryDateCommand -> DateParser: parseDate(itemExpiryDate)
            activate DateParser
            DateParser --> FindItemByExpiryDateCommand: itemDate
            deactivate DateParser

            FindItemByExpiryDateCommand -> FindItemByExpiryDateCommand: add formatted match if itemDate <= cutoffDate
            activate FindItemByExpiryDateCommand
            FindItemByExpiryDateCommand --> FindItemByExpiryDateCommand
            deactivate FindItemByExpiryDateCommand
        end
    end
end

alt matches is empty
    FindItemByExpiryDateCommand -> UI: showMessage("No items found ...")
    activate UI
    UI --> User: display no-match message
    deactivate UI
else matches found
    FindItemByExpiryDateCommand -> UI: showDivider()
    activate UI
    FindItemByExpiryDateCommand -> UI: showMessage("Items expiring by ...")
    FindItemByExpiryDateCommand -> UI: showNumberedList(matches)
    FindItemByExpiryDateCommand -> UI: showDivider()
    UI --> User: display matching items
    deactivate UI
end

deactivate FindItemByExpiryDateCommand
deactivate Duke
deactivate UI
@enduml
