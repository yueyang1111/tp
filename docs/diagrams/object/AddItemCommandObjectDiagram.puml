@startuml
title Object Diagram for AddItemCommand Feature
hide circle
left to right direction

object "<u>addParser:AddCommandParser</u>" as addParser
object "<u>addItemParser:AddItemCommandParser</u>" as addItemParser
object "<u>boolParser:BooleanFieldParser</u>" as boolParser
object "<u>cmd:AddItemCommand</u>" as addCommand {
  categoryName = "fruits"
}
object "<u>inventory:Inventory</u>" as inventory
object "<u>fruits:Category</u>" as fruits {
  name = "fruits"
}
object "<u>existingApple:Item</u>" as existingApple {
  name = "apple"
  quantity = 10
  binLocation = "A-1"
}
object "<u>incomingApple:Item</u>" as incomingApple {
  name = "apple"
  quantity = 20
  binLocation = "B-2"
}
object "<u>:UI</u>" as ui

note as N1
  Snapshot before command execution.
  addItemParser has already parsed the
  common fields and the shared boolean field,
  then created the AddItemCommand.
  existingApple is already in fruits.
end note

addParser --> addItemParser : delegates to >
addItemParser --> boolParser : uses >
addItemParser --> addCommand : creates >
addCommand --> incomingApple : holds >
addCommand --> inventory : queries >
addCommand --> ui : reports via >
inventory --> fruits : contains >
fruits --> existingApple : contains >
@enduml

