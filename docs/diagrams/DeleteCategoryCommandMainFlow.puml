@startuml
title Sequence Diagram for DeleteCategoryCommand (Main Control Flow Only)

autonumber
hide footbox

actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser
participant ":DeleteCommandParser" as DeleteCommandParser
participant ":DeleteCategoryCommand" as DeleteCategoryCommand
participant ":Inventory" as Inventory
participant ":Category" as Category

User -> UI: enter delete category command
activate UI
UI -> InventoryDock: input
activate InventoryDock
InventoryDock -> Parser: parse(input)
activate Parser

Parser -> DeleteCommandParser: parse(arguments)
activate DeleteCommandParser

create DeleteCategoryCommand
DeleteCommandParser -> DeleteCategoryCommand: DeleteCategoryCommand(categoryName)
activate DeleteCategoryCommand
DeleteCategoryCommand --> DeleteCommandParser: command
deactivate DeleteCategoryCommand
DeleteCommandParser --> Parser: command
deactivate DeleteCommandParser
Parser --> InventoryDock: command
deactivate Parser

InventoryDock -> DeleteCategoryCommand: execute(inventory, ui)
activate DeleteCategoryCommand
DeleteCategoryCommand -> Inventory: findCategoryByName(categoryName)
activate Inventory
Inventory --> DeleteCategoryCommand: category
deactivate Inventory

alt category is null
    DeleteCategoryCommand -> UI: showCategoryNotFound(categoryName)
    activate UI
    UI --> User: display error
    deactivate UI
else category found
    alt category is not empty
        DeleteCategoryCommand -> Category: getItemCount()
        activate Category
        Category --> DeleteCategoryCommand: itemCount
        deactivate Category

        DeleteCategoryCommand -> UI: showDeleteCategoryConfirmation(categoryName, itemCount)
        activate UI
        UI --> User: display confirmation prompt
        deactivate UI

        DeleteCategoryCommand -> UI: readCommand()
        activate UI
        UI --> DeleteCategoryCommand: response
        deactivate UI

        alt response is not "yes"
            DeleteCategoryCommand -> UI: showDeleteCategoryCancelled(categoryName)
            activate UI
            UI --> User: display cancellation
            deactivate UI
        else response is "yes"
            DeleteCategoryCommand -> Category: getItems().clear()
            activate Category
            Category --> DeleteCategoryCommand
            deactivate Category

            DeleteCategoryCommand -> UI: showCategoryItemsCleared(categoryName)
            activate UI
            UI --> User: display items cleared
            deactivate UI

            DeleteCategoryCommand -> UI: showCategoryDeleted(categoryName)
            activate UI
            UI --> User: display confirmation
            deactivate UI
        end
    else category is empty
        DeleteCategoryCommand -> UI: showCategoryDeleted(categoryName)
        activate UI
        UI --> User: display confirmation
        deactivate UI
    end
end

DeleteCategoryCommand --> InventoryDock: display information
deactivate DeleteCategoryCommand
deactivate InventoryDock
deactivate UI
@enduml

