@startuml
title Sequence Diagram for FindItemByKeywordCommand (Main Control Flow Only)

autonumber
hide footbox

actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser
participant ":FindItemParser" as FindItemParser
participant ":FindItemByKeywordCommand" as FindItemByKeywordCommand
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":Item" as Item

User -> UI: enter find keyword command
activate UI
UI -> InventoryDock: input
activate InventoryDock
InventoryDock -> Parser: parse(input)
activate Parser

Parser -> FindItemParser: parse(arguments)
activate FindItemParser
create FindItemByKeywordCommand
FindItemParser -> FindItemByKeywordCommand: FindItemByKeywordCommand(keyword)
activate FindItemByKeywordCommand
FindItemByKeywordCommand --> FindItemParser: command
deactivate FindItemByKeywordCommand
FindItemParser --> Parser: command
deactivate FindItemParser
Parser --> InventoryDock: command
deactivate Parser

InventoryDock -> FindItemByKeywordCommand: execute(inventory, ui)
activate FindItemByKeywordCommand
FindItemByKeywordCommand -> Inventory: getCategories()
activate Inventory
Inventory --> FindItemByKeywordCommand: categories
deactivate Inventory

loop for each category in categories
    FindItemByKeywordCommand -> Category: getItems()
    activate Category
    Category --> FindItemByKeywordCommand: items
    deactivate Category

    loop for each item in items
        FindItemByKeywordCommand -> Item: getName()
        activate Item
        Item --> FindItemByKeywordCommand: itemName
        deactivate Item

        note right of FindItemByKeywordCommand
            Check if itemName (lowercased)
            contains keyword (lowercased)
        end note
    end
end

alt no matches found
    FindItemByKeywordCommand -> UI: showMessage("No items found matching keyword: ...")
    activate UI
    UI --> User: display no-match message
    deactivate UI
else matches found
    FindItemByKeywordCommand -> UI: showDivider()
    activate UI
    FindItemByKeywordCommand -> UI: showMessage("Items matching keyword '...':")
    FindItemByKeywordCommand -> UI: showNumberedList(matches)
    FindItemByKeywordCommand -> UI: showDivider()
    UI --> User: display matching items
    deactivate UI
end

FindItemByKeywordCommand --> InventoryDock: display information
deactivate FindItemByKeywordCommand
deactivate InventoryDock
deactivate UI
@enduml

