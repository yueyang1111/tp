@startuml Sequence Diagram for DeleteItemCommand
actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser
participant ":DeleteCommandParser" as DeleteCommandParser
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":Item" as Item

User -> UI : 1 enter delete item command
UI -> InventoryDock : 2 input
InventoryDock -> Parser : 3 parse(input)
Parser -> DeleteCommandParser : 4 parse(arguments)
DeleteCommandParser -> DeleteCommandParser : 5 parseDeleteItem(categoryName, indexString)
DeleteCommandParser <-- DeleteCommandParser : 6 itemIndex
create ":DeleteItemCommand" as DeleteItemCommand
DeleteCommandParser -> DeleteItemCommand : 7 DeleteItemCommand(categoryName, itemIndex)
DeleteCommandParser <-- DeleteItemCommand : 8 command
Parser <-- DeleteCommandParser : 9 command
InventoryDock <-- Parser : 10 command
InventoryDock -> DeleteItemCommand : 11 execute(inventory, ui)
DeleteItemCommand -> Inventory : 12 findCategoryByName(categoryName)
DeleteItemCommand <-- Inventory : 13 category

alt [category is null]
    DeleteItemCommand -> UI : 14 showCategoryNotFound(categoryName)
    UI --> User : 15 display error

else [category found]
    alt [itemIndex < 1 or itemIndex > category.getItemCount()]
        DeleteItemCommand -> UI : 16 showError("Invalid item index: ...")
        UI --> User : 17 display error

    else [valid index]
        DeleteItemCommand -> Category : 18 getItem(itemIndex - 1)
        DeleteItemCommand <-- Category : 19 item
        DeleteItemCommand -> Category : 20 removeItem(itemIndex - 1)
        DeleteItemCommand <-- Category : 21
        DeleteItemCommand -> Item : 22 getName()
        DeleteItemCommand <-- Item : 23 itemName
        DeleteItemCommand -> UI : 24 showItemDeleted(itemName, categoryName)
        UI --> User : 25 display confirmation
    end
end

InventoryDock -> UI : 26 display information

@enduml
