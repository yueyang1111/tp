@startuml
title FindItemByKeywordCommand Matching Flow

autonumber
hide footbox

actor User
participant FindItemByKeywordCommand
participant Inventory
participant Category
participant Item

User -> FindItemByKeywordCommand : execute()
activate FindItemByKeywordCommand

FindItemByKeywordCommand -> Inventory : getCategories()
activate Inventory
Inventory --> FindItemByKeywordCommand : categories
deactivate Inventory

loop for each category
    FindItemByKeywordCommand -> Category : getItems()
    activate Category
    Category --> FindItemByKeywordCommand : items
    deactivate Category

    loop for each item
        FindItemByKeywordCommand -> Item : getName()
        activate Item
        Item --> FindItemByKeywordCommand : name
        deactivate Item

        alt name contains keyword
            FindItemByKeywordCommand -> FindItemByKeywordCommand : add to matches
        end
    end
end

FindItemByKeywordCommand --> User
deactivate FindItemByKeywordCommand

@enduml
