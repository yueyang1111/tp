@startuml
title Sequence Diagram for Sort Command (Main Control Flow)

autonumber
hide footbox

participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser
participant ":SortCommandParser" as SortCommandParser
participant ":SortCommand" as SortCommand
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":UI" as UI

InventoryDock -> Parser: parse("sort expirydate")
activate Parser

Parser -> SortCommandParser: parse("expirydate")
activate SortCommandParser

SortCommandParser -> SortCommandParser: trim input
activate SortCommandParser
SortCommandParser --> SortCommandParser
deactivate SortCommandParser

alt input is empty
    SortCommandParser --> Parser: throw MissingArgumentException
    Parser --> InventoryDock: exception
else valid sort type
    create SortCommand
    SortCommandParser -> SortCommand: SortCommand("expirydate")
    activate SortCommand
    SortCommand --> SortCommandParser

    SortCommandParser --> Parser: sortCommand
    deactivate SortCommandParser
    Parser --> InventoryDock: sortCommand
    deactivate Parser

    InventoryDock -> SortCommand: execute(inventory, ui)
    activate SortCommand

    SortCommand -> SortCommand: getSortedItemsByCategory(inventory)
    activate SortCommand

    SortCommand -> Inventory: getCategories()
    activate Inventory
    Inventory --> SortCommand: categories
    deactivate Inventory

    loop for each category
        SortCommand -> Category: getItems()
        activate Category
        Category --> SortCommand: original item list
        deactivate Category

        SortCommand -> SortCommand: create copied item list
        activate SortCommand
        SortCommand --> SortCommand
        deactivate SortCommand

        SortCommand -> SortCommand: getComparator()
        activate SortCommand

        alt sortType is "qty"
            SortCommand -> SortCommand: Comparator.comparing(Item::getQuantity).reversed()
            activate SortCommand
            SortCommand --> SortCommand
            deactivate SortCommand
        else sortType is "expirydate"
            SortCommand -> SortCommand: Comparator.comparing(parseExpiryDate(...))
            activate SortCommand
            SortCommand --> SortCommand
            deactivate SortCommand
        else sortType is "name"
            SortCommand -> SortCommand: Comparator.comparing(Item::getName,\nString.CASE_INSENSITIVE_ORDER)
            activate SortCommand
            SortCommand --> SortCommand
            deactivate SortCommand
        else else
            SortCommand --> InventoryDock: throw InvalidCommandException
        end

        SortCommand --> SortCommand: comparator
        deactivate SortCommand

        SortCommand -> SortCommand: sortedItems.sort(comparator)
        activate SortCommand
        SortCommand --> SortCommand
        deactivate SortCommand

        opt expiry-date sorting
            loop for each item with expiry date comparison
                SortCommand -> SortCommand: parseExpiryDate(item.getExpiryDate())
                activate SortCommand

                alt date is valid
                    SortCommand -> SortCommand: DateParser.parseDate(expiryDate)
                    activate SortCommand
                    SortCommand --> SortCommand: LocalDate
                    deactivate SortCommand
                else date is invalid
                    SortCommand --> SortCommand: LocalDate.MAX
                end
                deactivate SortCommand
            end
        end

        SortCommand -> SortCommand: add sortedItems to sortedItemsByCategory
        activate SortCommand
        SortCommand --> SortCommand
        deactivate SortCommand
    end

    SortCommand --> SortCommand: sortedItemsByCategory
    deactivate SortCommand

    SortCommand -> SortCommand: formatSortLabel()
    activate SortCommand

    alt sortType is "name"
        SortCommand --> SortCommand: "name"
    else sortType is "qty"
        SortCommand --> SortCommand: "quantity"
    else sortType is "expirydate"
        SortCommand --> SortCommand: "expiry date"
    else else
        SortCommand --> InventoryDock: throw InvalidCommandException
    end
    deactivate SortCommand

    SortCommand -> UI: showSortedInventory(inventory,\nsortedItemsByCategory, sortLabel)
    activate UI
    UI --> SortCommand
    deactivate UI

    SortCommand --> InventoryDock
    deactivate SortCommand
else else
    SortCommandParser --> Parser: throw InvalidCommandException
    Parser --> InventoryDock: exception
end

@enduml
