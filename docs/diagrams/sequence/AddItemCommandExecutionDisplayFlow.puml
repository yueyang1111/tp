@startuml
title Add Item Command - Execution and Error Handling (Continued from Diagram 1)

autonumber
hide footbox

actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":AddItemCommand" as AddItemCommand
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":DuplicateIdentityParser" as DuplicateIdentityParser
participant ":DateParser" as DateParser

activate UI
activate InventoryDock

InventoryDock -> AddItemCommand: execute(inventory, ui)
activate AddItemCommand

AddItemCommand -> Inventory: findCategoryByName(categoryName)
activate Inventory
Inventory --> AddItemCommand: category / null
deactivate Inventory

alt category not found
    AddItemCommand --> InventoryDock: throw CategoryNotFoundException

    InventoryDock -> UI: showError(...)
    UI --> User: display error

else else
    AddItemCommand -> DuplicateIdentityParser: findDuplicateItem(category, item)
    activate DuplicateIdentityParser
    DuplicateIdentityParser --> AddItemCommand: duplicateItem / null
    deactivate DuplicateIdentityParser

    alt duplicate found
        AddItemCommand --> InventoryDock: throw DuplicateItemException

        InventoryDock -> UI: showError(...)
        UI --> User: display error

    else else
        AddItemCommand -> Category: addItem(item)
        activate Category
        Category --> AddItemCommand
        deactivate Category

        AddItemCommand -> UI: showItemAdded(...)
        UI --> User: display confirmation

        AddItemCommand -> DateParser: parseDate(item.getExpiryDate())
        activate DateParser
        DateParser --> AddItemCommand: expiryDate
        deactivate DateParser

        alt expiryDate is before today
            AddItemCommand -> UI: showMessage(...)
            UI --> User: display warning
        end

        AddItemCommand --> InventoryDock --: return
    end
end

InventoryDock --> UI
deactivate InventoryDock
UI --> User
deactivate UI
@enduml
