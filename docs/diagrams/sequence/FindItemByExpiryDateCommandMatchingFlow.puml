@startuml
title Sequence Diagram for FindItemByExpiryDateCommand (Date Parsing and Matching)

autonumber
hide footbox

actor User
participant ":FindItemByExpiryDateCommand" as FindItemByExpiryDateCommand
participant ":DateParser" as DateParser
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":Item" as Item

User -> FindItemByExpiryDateCommand: execute(inventory, ui)
activate FindItemByExpiryDateCommand

FindItemByExpiryDateCommand -> DateParser: parseDate(expiryDateInput)
activate DateParser
DateParser --> FindItemByExpiryDateCommand: cutoffDate
deactivate DateParser

FindItemByExpiryDateCommand -> Inventory: getCategories()
activate Inventory
Inventory --> FindItemByExpiryDateCommand: categories
deactivate Inventory

loop for each category
    FindItemByExpiryDateCommand -> Category: getItems()
    activate Category
    Category --> FindItemByExpiryDateCommand: items
    deactivate Category

    loop for each item
        FindItemByExpiryDateCommand -> Item: getExpiryDate()
        activate Item
        Item --> FindItemByExpiryDateCommand: itemExpiryDate
        deactivate Item


            FindItemByExpiryDateCommand -> DateParser: parseDate(itemExpiryDate)
            activate DateParser
            DateParser --> FindItemByExpiryDateCommand: itemDate
            deactivate DateParser

        opt itemDate <= cutoffDate
            FindItemByExpiryDateCommand -> FindItemByExpiryDateCommand: add match
            activate FindItemByExpiryDateCommand
            FindItemByExpiryDateCommand --> FindItemByExpiryDateCommand
            deactivate FindItemByExpiryDateCommand
        end
    end
end

FindItemByExpiryDateCommand --> User
deactivate FindItemByExpiryDateCommand
@enduml
