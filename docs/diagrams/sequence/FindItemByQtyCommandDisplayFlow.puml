@startuml
title Sequence Diagram for FindItemByQtyCommand (Result Display)

autonumber
hide footbox

actor User
participant ":FindItemByQtyCommand" as FindItemByQtyCommand
participant ":UI" as UI

activate FindItemByQtyCommand
alt no matches found
    FindItemByQtyCommand -> UI: formatNoItemsFoundMessage("with quantity: " + qtyInput)
    activate UI
    UI --> FindItemByQtyCommand: noItemsMessage
    FindItemByQtyCommand -> UI: showMessage(noItemsMessage)
    UI --> User: display no-match message
    deactivate UI
else else
    FindItemByQtyCommand -> UI: formatFoundItemsMessage(matches.size(), "with quantity '" + qtyInput + "'")
    activate UI
    UI --> FindItemByQtyCommand: foundItemsMessage
    FindItemByQtyCommand -> UI: showDivider()
    FindItemByQtyCommand -> UI: formatFindResultsHeader("with quantity: " + qtyInput)
    UI --> FindItemByQtyCommand: resultsHeader
    FindItemByQtyCommand -> UI: showMessage(resultsHeader)
    FindItemByQtyCommand -> UI: showNumberedList(matches)
    FindItemByQtyCommand -> UI: showDivider()
    UI --> User: display matching items
    deactivate UI
end
@enduml

