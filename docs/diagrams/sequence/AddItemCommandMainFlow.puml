@startuml
title Sequence Diagram for AddItemCommand (Main Control Flow Only)

autonumber
hide footbox

actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser
participant ":AddCommandParser" as AddCommandParser
participant ":AddItemCommandParser" as AddItemCommandParser
participant ":InputValidator" as InputValidator
participant ":CommonFieldParser" as CommonFieldParser
participant ":FruitParser" as FruitParser
participant ":AddItemCommand" as AddItemCommand
participant ":Inventory" as Inventory
participant ":Category" as Category

User -> UI: enter add command
activate UI
UI -> InventoryDock: input
activate InventoryDock
InventoryDock -> Parser: parse(input)
activate Parser

Parser -> AddCommandParser: parse(arguments)
activate AddCommandParser

AddCommandParser -> AddCommandParser: validateRequiredFields(trimmedInput)
activate AddCommandParser
AddCommandParser --> AddCommandParser
deactivate AddCommandParser

AddCommandParser -> AddCommandParser: extractCategory(trimmedInput)
activate AddCommandParser
AddCommandParser --> AddCommandParser: category
deactivate AddCommandParser

alt category == fruits
    AddCommandParser -> AddItemCommandParser: handleFruit(trimmedInput)
    activate AddItemCommandParser

    AddItemCommandParser -> InputValidator: validate(input, ...)
    activate InputValidator
    InputValidator --> AddItemCommandParser
    deactivate InputValidator

    AddItemCommandParser -> CommonFieldParser: parse(input, "size/")
    activate CommonFieldParser
    CommonFieldParser --> AddItemCommandParser: commonFields
    deactivate CommonFieldParser

    AddItemCommandParser -> FruitParser: parse(input)
    activate FruitParser
    FruitParser --> AddItemCommandParser: fruitFields
    deactivate FruitParser

    create AddItemCommand
    AddItemCommandParser -> AddItemCommand: AddItemCommand(categoryName, item)
    activate AddItemCommand
    AddItemCommand --> AddItemCommandParser: command

    AddItemCommandParser --> AddCommandParser: command
    deactivate AddItemCommandParser
else other supported category
    AddCommandParser -> AddItemCommandParser: handleCategory(input)
    activate AddItemCommandParser
    AddItemCommandParser --> AddCommandParser: command
    deactivate AddItemCommandParser
end

AddCommandParser --> Parser: command
deactivate AddCommandParser
Parser --> InventoryDock: command
deactivate Parser

InventoryDock -> AddItemCommand: execute(inventory, ui)
activate AddItemCommand
AddItemCommand -> Inventory: findCategoryByName(categoryName)
activate Inventory
loop for each category in inventory
    Inventory -> Category: getName()
    activate Category
    Category --> Inventory: name
    deactivate Category
end
Inventory --> AddItemCommand: matchingCategory
deactivate Inventory

AddItemCommand -> Category: addItem(item)
activate Category
Category --> AddItemCommand
deactivate Category

AddItemCommand -> UI: showItemAdded(...)
activate UI
UI --> User: display confirmation
deactivate UI
deactivate AddItemCommand

deactivate InventoryDock
deactivate UI
@enduml

