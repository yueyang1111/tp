@startuml Sequence Diagram for DeleteCategoryCommand
actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser
participant ":DeleteCommandParser" as DeleteCommandParser
participant ":Inventory" as Inventory
participant ":Category" as Category

User -> UI : 1 enter delete category command
UI -> InventoryDock : 2 input
InventoryDock -> Parser : 3 parse(input)
Parser -> DeleteCommandParser : 4 parse(arguments)
create ":DeleteCategoryCommand" as DeleteCategoryCommand
DeleteCommandParser -> DeleteCategoryCommand : 5 DeleteCategoryCommand(categoryName)
DeleteCommandParser <-- DeleteCategoryCommand : 6 command
Parser <-- DeleteCommandParser : 7 command
InventoryDock <-- Parser : 8 command
InventoryDock -> DeleteCategoryCommand : 9 execute(inventory, ui)
DeleteCategoryCommand -> Inventory : 10 findCategoryByName(categoryName)
DeleteCategoryCommand <-- Inventory : 11 category

alt [category is null]
    DeleteCategoryCommand -> UI : 12 showCategoryNotFound(categoryName)
    UI --> User : 13 display error

else [category found]
    alt [category is not empty]
        DeleteCategoryCommand -> Category : 14 getItemCount()
        DeleteCategoryCommand <-- Category : 15 itemCount
        DeleteCategoryCommand -> UI : 16 showDeleteCategoryConfirmation(categoryName, itemCount)
        UI --> User : 17 display confirmation prompt
        DeleteCategoryCommand -> UI : 18 readCommand()
        DeleteCategoryCommand <-- UI : 19 response

        alt [response is not "yes"]
            DeleteCategoryCommand -> UI : 20 showDeleteCategoryCancelled(categoryName)
            UI --> User : 21 display cancellation

        else [response is "yes"]
            DeleteCategoryCommand -> Category : 22 getItems().clear()
            DeleteCategoryCommand <-- Category : 23
            DeleteCategoryCommand -> UI : 24 showCategoryItemsCleared(categoryName)
            UI --> User : 25 display items cleared
            DeleteCategoryCommand -> UI : 26 showCategoryDeleted(categoryName)
            UI --> User : 27 display confirmation
        end

    else [category is empty]
        DeleteCategoryCommand -> UI : 28 showCategoryDeleted(categoryName)
        UI --> User : 29 display confirmation
    end
end

InventoryDock -> UI : 30 display information

@enduml
