@startuml
title Sequence Diagram for HelpCommand (Main Control Flow Only)

autonumber
hide footbox

actor User
participant ":UI" as UI
participant ":InventoryDock" as InventoryDock
participant ":Parser" as Parser

User -> UI: enter help command
activate UI
UI -> InventoryDock: input
activate InventoryDock
InventoryDock -> Parser: parse(input)
activate Parser

create ":HelpCommand" as HelpCommand
Parser -> HelpCommand: HelpCommand(arguments)
activate HelpCommand
HelpCommand --> Parser: command
deactivate HelpCommand
Parser --> InventoryDock: command
deactivate Parser

InventoryDock -> HelpCommand: execute(inventory, ui)
activate HelpCommand

alt arguments is empty
    HelpCommand -> UI: showHelp()
    activate UI
    UI --> User: display available commands and User Guide link
    deactivate UI
else else
    HelpCommand -> UI: showError("Invalid input", "help command does not take arguments. Use: help")
    activate UI
    UI --> User: display error message
    deactivate UI
end

HelpCommand --> InventoryDock
deactivate HelpCommand
InventoryDock --> UI
deactivate InventoryDock
UI --> User
deactivate UI
@enduml
